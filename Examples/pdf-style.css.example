body {
    line-height: 1; /* Adjust this number as needed */
}

h2 {
    border-bottom: 1px solid #000000; /* This is the standard light gray color */
    padding-bottom: 0.3em;           /* Adds a little "breathing room" above the line */
    font-size: 1em !important;
    font-weight: bold !important;
}
/* 1. Tighten space under headers (Education) */
h1, h2, h3 {
    margin-top: 8px !important;
    margin-bottom: 5px !important;
}

/* 2. Tighten space under the University name (if it's a paragraph or bold line) */
p {
    margin-top: 0px !important;
    margin-bottom: 0px !important;
    line-height: 1.1; /* Brings the lines of text closer together */
}

/* 3. Tighten the space between bullet points */
li {
    margin-bottom: 2px !important;
}

/* 4. Remove the gap between the University name and the start of the list */
ul {
    margin-top: 0px !important;
    margin-bottom: 4px !important;
    padding-top: 0px !important;
}

/* Targets all bold text rendered from Markdown **bold** or <b> tags */
strong, b {
    font-size: 0.92em; /* Makes bold text 8% smaller than the surrounding text */
    font-weight: 600;  /* Optional: reduces "heaviness" if 700 is too thick */
}